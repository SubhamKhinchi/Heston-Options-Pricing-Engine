   "source": [
    "df['mispricing_$']   = df['model_price'] - df['mid_price']\n",
    "df['mispricing_%']   = df['mispricing_$'] / df['mid_price'] * 100\n",
    "\n",
    "SHOW_COLS = ['type', 'maturity', 'strike', 'T', 'mid_price', 'model_price',\n",
    "             'mispricing_$', 'mispricing_%', 'market_iv', 'model_iv']\n",
    "\n",
