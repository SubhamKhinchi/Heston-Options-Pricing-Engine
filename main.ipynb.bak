    "print('Top 10 — Model UNDER-PRICED (market > model, potential market sells)')\n",
    "print('─' * 110)\n",
    "under = df.nsmallest(10, 'mispricing_$')[SHOW_COLS]\n",
    "print(under.to_string(index=False))"
